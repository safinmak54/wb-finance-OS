# Public — exposed to the browser. Safe by design.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# Server-only — never imported in any "use client" file.
# Used for admin operations (create/invite users from /admin pages).
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails that always resolve as admin.
# Useful to bootstrap a fresh deployment or as a break-glass recovery path.
# Listed emails cannot be demoted from the Users page; remove from this
# var to revoke.
ADMIN_EMAILS=

# Anthropic — server-only, accessed only from app/api/ai/route.ts
ANTHROPIC_API_KEY=

# Upstash (rate limiting) — server-only
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
